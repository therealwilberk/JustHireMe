# JustHireMe — environment variable reference
#
# Copy to .env for shell-level overrides. All keys resolved via the config layer.
# Set these in your environment to avoid SQLite secret storage (recommended).

# ── LLM Provider API keys ──────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
KIMI_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
CEREBRAS_API_KEY=
PERPLEXITY_API_KEY=
HUGGINGFACE_API_KEY=
CUSTOM_API_KEY=

# ── Scraping / Data enrichment keys ─────────────────────────────────
APIFY_TOKEN=
HUNTER_API_KEY=
PROXYCURL_API_KEY=
X_BEARER_TOKEN=
TWITTER_BEARER_TOKEN=

# ── Local model endpoint (optional) ────────────────────────────────
OLLAMA_URL=http://localhost:11434/v1

# ── Application behavior ───────────────────────────────────────────
JHM_AUTO_APPLY=false
PLAYWRIGHT_CHROMIUM_EXECUTABLE=
JHM_CONFIG_DIR=
JHM_LOG_LEVEL=INFO
